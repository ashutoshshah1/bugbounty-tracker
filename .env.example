# Core behavior
PORT=3001
TRACK_PLATFORMS=Sherlock,Immunefi,Code4rena,HackenProof
TRACK_SCOPE_KEYWORDS=
BBRADAR_INTERVAL_MINUTES=30
GITHUB_INTERVAL_MINUTES=60
NOTIFICATION_RETRY_INTERVAL_MINUTES=5
VIGILSEEK_ENABLED=true
VIGILSEEK_BASE_URL=https://new-api.vigilseek.com
DIGEST_ENABLED=true
DIGEST_INTERVAL_HOURS=24
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
SLA_REMINDER_ENABLED=true
SLA_REMINDER_INTERVAL_MINUTES=30
SOURCE_ALERT_COOLDOWN_MINUTES=60
JOB_WORKER_COUNT=4
STALE_JOB_TIMEOUT_MINUTES=120
HOUSEKEEPING_ENABLED=true
HOUSEKEEPING_INTERVAL_HOURS=6
EVENT_RETENTION_DAYS=120
JOB_RETENTION_DAYS=30
BOOTSTRAP_NOTIFY_EXISTING=false
TIMEZONE=UTC
REQUEST_TIMEOUT_SECONDS=30
DATABASE_BUSY_TIMEOUT_MS=5000
API_KEY_SIGNING_SECRET=change-me-strong-secret

# Storage
DATA_DIR=./data
DATABASE_PATH=./data/tracker.db
REPORTS_DIR=./data/reports

# Telegram bot notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GITHUB_TELEGRAM_BOT_TOKEN=
GITHUB_TELEGRAM_CHAT_ID=

# Optional GitHub token (recommended to avoid rate limits)
GITHUB_TOKEN=

# GitHub OAuth login (for website "Login with GitHub")
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/auth/github/callback
GITHUB_OAUTH_SCOPE=read:user user:email

# Optional admin bootstrap (used for /api/team/* and /api/alert-rules writes)
BOOTSTRAP_ADMIN_USERNAME=owner
BOOTSTRAP_ADMIN_API_KEY=
